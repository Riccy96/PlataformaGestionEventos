@model IEnumerable<PlataformaGestionEventos.Models.Evento>
@{
ViewData["Title"] = "Lista de Eventos";
}
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    .custom-dashboard { font-family: 'Poppins', sans-serif; background-color: #21212b; color: #b5b5be; border-radius: 16px; padding: 2rem; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3); }
    .custom-title { font-weight: 600; color: #ffffff; font-size: 1.75rem; }
    .btn-custom-add { background: linear-gradient(135deg, #ff527b, #ff715b); color: white; border: none; padding: 10px 24px; border-radius: 20px; font-weight: 500; transition: all 0.3s ease; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    .btn-custom-add:hover { background: linear-gradient(135deg, #ff715b, #ff527b); color: white; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255, 82, 123, 0.4); }
    .custom-table-container { margin-top: 1.5rem; }
    .custom-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; color: #a5a5b1; }
    .custom-table th { color: #7e7e8f; font-weight: 500; text-transform: capitalize; padding: 12px 16px; border: none; font-size: 0.9rem; }
    .custom-table tbody tr { background-color: #262633; transition: all 0.2s ease; }
    .custom-table tbody tr td:first-child { border-top-left-radius: 10px; border-bottom-left-radius: 10px; padding-left: 20px; }
    .custom-table tbody tr td:last-child { border-top-right-radius: 10px; border-bottom-right-radius: 10px; padding-right: 20px; }
    .custom-table tbody td { padding: 16px; border: none; vertical-align: middle; font-size: 0.95rem; }
    .custom-table tbody tr.row-highlighted { background: linear-gradient(90deg, #624b91, #3b508a); color: #ffffff; }
    .custom-table tbody tr.row-highlighted td { color: #ffffff; }
    .btn-action { background: transparent; border: none; color: #7e7e8f; padding: 6px 10px; font-size: 1.1rem; transition: color 0.2s; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .btn-action:hover { color: #ffffff; }
    .btn-action.edit:hover { color: #ffc107; }
    .btn-action.view:hover { color: #0dcaf0; }
    .btn-action.delete:hover { color: #dc3545; }
    .btn-action.return:hover { color: #a370f7; }
    .row-highlighted .btn-action { color: #e2e2e2; }
    .row-highlighted .btn-action:hover { color: #ffffff; }
</style>
<div class="custom-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="custom-title m-0">Eventos</h1>
        <a asp-action="Crear" class="btn-custom-add"><span>+</span> Nuevo Evento</a>
    </div>
    <div class="table-responsive custom-table-container">
        <table class="custom-table">
            <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Capacidad</th>
                <th>Sala</th>
                <th style="width: 240px; text-align: center;">Acciones</th>
            </tr>
            </thead>
            <tbody>
            @{ bool esPrimeraFila = true; }
            @foreach (var evento in Model)
            {
            <tr class="@(esPrimeraFila ? "row-highlighted" : "")">
                <td style="font-weight: 500;">@evento.EventoId</td>
                <td>@evento.Nombre</td>
                <td>@evento.Descripcion</td>
                <td>@evento.FechaInicio</td>
                <td>@evento.FechaFin</td>
                <td>@evento.CapacidadMaxima</td>
                <td>@evento.Sala?.nombre</td>
                <td style="text-align: center; vertical-align: middle;">
                    <div class="d-flex justify-content-center align-items-center gap-1">
                        @if (esPrimeraFila)
                        {
                        <a asp-action="Editar" asp-route-id="@evento.EventoId" class="btn-action font-weight-bold" title="Editar"><i class="bi bi-check-lg"></i></a>
                        <a asp-action="Ver" asp-route-id="@evento.EventoId" class="btn-action view" title="Ver"><i class="bi bi-eye"></i></a>
                        <form asp-action="DevolverRecursos" asp-route-id="@evento.EventoId" method="post" class="m-0" onsubmit="return confirm('¿Está seguro de devolver los recursos de este evento?');">
                            <button type="submit" class="btn-action return" title="Devolver Recursos"><i class="bi bi-arrow-counterclockwise"></i></button>
                        </form>
                        <a asp-action="Eliminar" asp-route-id="@evento.EventoId" class="btn-action font-weight-bold" title="Eliminar"><i class="bi bi-x-lg"></i></a>
                        }
                        else
                        {
                        <a asp-action="Editar" asp-route-id="@evento.EventoId" class="btn-action edit" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                        <a asp-action="Ver" asp-route-id="@evento.EventoId" class="btn-action view" title="Ver"><i class="bi bi-eye"></i></a>
                        <form asp-action="DevolverRecursos" asp-route-id="@evento.EventoId" method="post" class="m-0" onsubmit="return confirm('¿Está seguro de devolver los recursos de este evento?');">
                            <button type="submit" class="btn-action return" title="Devolver Recursos"><i class="bi bi-arrow-counterclockwise"></i></button>
                        </form>
                        <a asp-action="Eliminar" asp-route-id="@evento.EventoId" class="btn-action delete" title="Eliminar"><i class="bi bi-trash3-fill"></i></a>
                        }
                    </div>
                </td>
            </tr>
            esPrimeraFila = false;
            }
            </tbody>
        </table>
    </div>
</div>
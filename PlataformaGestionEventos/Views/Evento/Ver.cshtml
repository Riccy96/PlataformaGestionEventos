@model PlataformaGestionEventos.Models.Evento
@{
    ViewData["Title"] = "Detalle del Evento";
}
<style>
    .custom-dashboard { font-family: 'Poppins', sans-serif; background-color: #21212b; color: #b5b5be; border-radius: 16px; padding: 2.5rem; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3); max-width: 700px; margin: 0 auto; }
    .custom-title { font-weight: 600; color: #ffffff; font-size: 1.75rem; }
    .custom-subtitle { font-weight: 500; color: #ffffff; font-size: 1.25rem; margin-top: 1.5rem; }
    .custom-hr { border-top: 1px solid #2d2d3d; opacity: 1; margin: 1.5rem 0; }
    .custom-label { color: #7e7e8f; font-weight: 500; font-size: 0.9rem; }
    .custom-value { color: #ffffff; font-size: 0.95rem; margin-bottom: 1rem; }
    .custom-table { border-color: #2d2d3d; color: #b5b5be; }
    .custom-table thead th { background-color: #262633; color: #ffffff; border-color: #2d2d3d; font-weight: 500; font-size: 0.9rem; }
    .custom-table tbody td { border-color: #2d2d3d; vertical-align: middle; background-color: transparent; color: #b5b5be; }
    .custom-table tbody tr { color: #b5b5be; }
    .btn-custom-edit { background: linear-gradient(135deg, #ff527b, #ff715b); color: white; border: none; padding: 12px 30px; border-radius: 20px; font-weight: 500; transition: all 0.3s ease; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .btn-custom-edit:hover { background: linear-gradient(135deg, #ff715b, #ff527b); color: white; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255, 82, 123, 0.4); }
    .btn-custom-back { background: transparent; border: 1px solid #2d2d3d; color: #7e7e8f; padding: 12px 30px; border-radius: 20px; font-weight: 500; transition: all 0.2s ease; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .btn-custom-back:hover { border-color: #5c5c70; color: #ffffff; }
</style>
<div class="custom-dashboard">
    <h1 class="custom-title m-0 text-center">Detalle del Evento</h1>
    <div class="custom-hr"></div>
    <div class="row px-2">
        <div class="col-sm-3 custom-label">Nombre</div>
        <div class="col-sm-9 custom-value">@Model.Nombre</div>
        <div class="col-sm-3 custom-label">Descripción</div>
        <div class="col-sm-9 custom-value">@Model.Descripcion</div>
        <div class="col-sm-3 custom-label">Fecha Inicio</div>
        <div class="col-sm-9 custom-value">@Model.FechaInicio</div>
        <div class="col-sm-3 custom-label">Fecha Fin</div>
        <div class="col-sm-9 custom-value">@Model.FechaFin</div>
        <div class="col-sm-3 custom-label">Capacidad Máxima</div>
        <div class="col-sm-9 custom-value">@Model.CapacidadMaxima</div>
        <div class="col-sm-3 custom-label">Sala</div>
        <div class="col-sm-9 custom-value">@Model.Sala?.nombre</div>
    </div>
    <div class="custom-hr"></div>
    <h4 class="custom-subtitle mb-3">Recursos asignados</h4>
    @if (Model.RecursosEvento != null && Model.RecursosEvento.Any())
    {
        <table class="table table-bordered custom-table">
            <thead>
                <tr>
                    <th>Recurso</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var recurso in Model.RecursosEvento)
            {
                <tr>
                    <td>@recurso.Recurso?.Nombre</td>
                    <td>@recurso.cantidad</td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted small px-2">No hay recursos asignados.</p>
    }
    <div class="custom-hr"></div>
    <div class="d-flex justify-content-between align-items-center pt-2">
        <a asp-action="Index" class="btn-custom-back">Volver</a>
        <a asp-action="Editar" asp-route-id="@Model.EventoId" class="btn-custom-edit">Editar</a>
    </div>
</div>
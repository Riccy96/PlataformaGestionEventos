@model IEnumerable<PlataformaGestionEventos.Models.Evento>
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .db-card {
        background-color: #21212b;
        border: 1px solid #2d2d3d;
        border-radius: 16px;
        padding: 1.5rem;
        transition: transform 0.2s ease;
    }
    .db-card:hover {
        transform: translateY(-2px);
    }
 
    .main-banner {
        background: linear-gradient(135deg, #1abc9c, #00bd9d);
        color: #1a1a22;
        min-height: 180px;
        display: flex;
        align-items: center;
    }
    .side-banner {
        background: linear-gradient(135deg, #a855f7, #6366f1);
        color: white;
        min-height: 180px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .db-icon-box {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        margin-bottom: 1rem;
    }
    
    .icon-sala { background-color: rgba(234, 179, 8, 0.1); color: #eab308; }
    .icon-evento { background-color: rgba(239, 68, 68, 0.1); color: #ef4444; }
    .icon-recurso { background-color: rgba(59, 130, 246, 0.1); color: #3b82f6; }
    
    .text-muted-custom {
        color: #7e7e8f;
    }
    .db-progress {
        height: 4px;
        background-color: #2d2d3d;
        border-radius: 2px;
        margin-top: 1rem;
    }
    .list-recent-item {
        background-color: #1a1a22;
        border: 1px solid #2d2d3d;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.75rem;
    }
</style>

<div class="container-fluid px-0 w-100 clearfix">
    
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-white fw-bold mb-1">Bienvenido!</h2>
            <p class="text-muted-custom small mb-0">Salas, Eventos y Recursos de la Plataforma</p>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="row g-4">
                
                <div class="col-12">
                    <div class="db-card main-banner text-dark position-relative overflow-hidden">
                        <div class="py-2">
                            <h4 class="fw-bold mb-2">Administracion General</h4>
                            <p class="mb-3 opacity-75 small">Monitorea en tiempo real la disponibilidad de las salas, las inscripciones realizadas y los eventos programados.</p>
                            <a asp-controller="Evento" asp-action="Index" class="btn btn-dark btn-sm rounded-pill px-4 text-white">Ver Evento</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="db-card h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="db-icon-box icon-sala">
                                <i class="bi bi-door-open-fill"></i>
                            </div>
                            <button class="btn p-0 text-muted-custom"><i class="bi bi-three-dots-vertical"></i></button>
                        </div>
                        <h6 class="text-muted-custom mb-1 fw-medium small">Salas de Conferencias</h6>
                        <h3 class="text-white fw-bold m-0">@ViewBag.TotalSalas</h3>
                        <div class="db-progress">
                            <div class="bg-warning h-100" style="width: 70%"></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="db-card h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="db-icon-box icon-evento">
                                <i class="bi bi-calendar-event-fill"></i>
                            </div>
                            <button class="btn p-0 text-muted-custom"><i class="bi bi-three-dots-vertical"></i></button>
                        </div>
                        <h6 class="text-muted-custom mb-1 fw-medium small">Eventos Programados</h6>
                        <h3 class="text-white fw-bold m-0">@ViewBag.TotalEventos</h3>
                        <div class="db-progress">
                            <div class="bg-danger h-100" style="width: 50%"></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="db-card h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="db-icon-box icon-recurso">
                                <i class="bi bi-cpu-fill"></i>
                            </div>
                            <button class="btn p-0 text-muted-custom"><i class="bi bi-three-dots-vertical"></i></button>
                        </div>
                        <h6 class="text-muted-custom mb-1 fw-medium small">Recursos de Inventario</h6>
                        <h3 class="text-white fw-bold m-0">@ViewBag.TotalRecursos</h3>
                        <div class="db-progress">
                            <div class="bg-primary h-100" style="width: 85%"></div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="db-card">
                        <h5 class="text-white fw-semibold mb-4 fs-6">Resumen Adicional de Activos</h5>
                        <div class="row py-2 text-center text-md-start">
                            <div class="col-md-6 border-end border-secondary border-opacity-25 mb-3 mb-md-0">
                                <div class="d-flex align-items-center justify-content-center justify-content-md-start">
                                    <span class="p-2 bg-info bg-opacity-10 text-info rounded-circle me-3">
                                        <i class="bi bi-journal-check fs-4"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-white fw-bold mb-0">@ViewBag.TotalInscripciones</h3>
                                        <p class="text-muted-custom small mb-0">Inscripciones Procesadas</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center justify-content-center justify-content-md-start ps-0 ps-md-3">
                                    <span class="p-2 bg-success bg-opacity-10 text-success rounded-circle me-3">
                                        <i class="bi bi-people-fill fs-4"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-white fw-bold mb-0">@ViewBag.TotalAsistentes</h3>
                                        <p class="text-muted-custom small mb-0">Asistentes</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-lg-4">
            <div class="row g-4">
                
                <div class="col-12">
                    <div class="db-card side-banner text-center py-4 shadow">
                        <div class="mb-2 opacity-75">
                            <i class="bi bi-lightning-charge-fill fs-2"></i>
                        </div>
                        <h5 class="fw-bold mb-1 fs-5">Inscripción Veloz</h5>
                        <p class="small px-3 mb-3 opacity-75" style="font-size: 0.85rem;">¿Llegó un nuevo asistente presencial? Registra su participación en los eventos en curso al instante.</p>
                        <a asp-controller="Inscripcion" asp-action="Crear" class="btn btn-light rounded-pill px-4 text-dark fw-semibold btn-sm shadow-sm">Nueva Inscripción</a>
                    </div>
                </div>

                <div class="col-12">
                    <div class="db-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-white fw-semibold m-0 small">Últimos Eventos Creados</h6>
                            <i class="bi bi-clock-history text-muted-custom"></i>
                        </div>

                        <div class="d-flex flex-column">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var evento in Model)
                                {
                                    <div class="list-recent-item d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-bookmark-star text-danger me-3 fs-5"></i>
                                            <div>
                                                <p class="text-white small fw-medium mb-0 text-truncate" style="max-width: 150px;">@evento.Nombre</p>
                                                <span class="text-muted-custom text-mini" style="font-size: 0.72rem;">Reciente</span>
                                            </div>
                                        </div>
                                        <span class="badge bg-dark border border-secondary text-muted-custom rounded-pill" style="font-size: 0.7rem;">Activo</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted-custom small">
                                    <i class="bi bi-folder-x display-6 d-block mb-2"></i>
                                    No hay eventos registrados recientemente.
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
        
    </div>
</div>
@model PlataformaGestionEventos.Models.Recurso
@{
    ViewData["Title"] = "Nuevo Recurso";
}
<style>
    .custom-dashboard { font-family: 'Poppins', sans-serif; background-color: #21212b; color: #b5b5be; border-radius: 16px; padding: 2.5rem; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3); max-width: 600px; margin: 0 auto; }
    .custom-title { font-weight: 600; color: #ffffff; font-size: 1.75rem; }
    .custom-hr { border-top: 1px solid #2d2d3d; opacity: 1; margin: 1.5rem 0; }
    .custom-label { color: #7e7e8f; font-weight: 500; font-size: 0.9rem; margin-bottom: 8px; }
    .custom-control { background-color: #262633; border: 1px solid #2d2d3d; color: #ffffff; border-radius: 10px; padding: 12px 16px; font-size: 0.95rem; transition: all 0.2s ease; }
    .custom-control:focus { background-color: #262633; border-color: #ff527b; color: #ffffff; box-shadow: 0 0 0 3px rgba(255, 82, 123, 0.15); }
    .custom-control::placeholder { color: #5c5c70; }
    .btn-custom-save { background: linear-gradient(135deg, #ff527b, #ff715b); color: white; border: none; padding: 12px 30px; border-radius: 20px; font-weight: 500; transition: all 0.3s ease; }
    .btn-custom-save:hover { background: linear-gradient(135deg, #ff715b, #ff527b); color: white; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255, 82, 123, 0.4); }
    .btn-custom-back { background: transparent; border: 1px solid #2d2d3d; color: #7e7e8f; padding: 12px 30px; border-radius: 20px; font-weight: 500; transition: all 0.2s ease; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .btn-custom-back:hover { border-color: #5c5c70; color: #ffffff; }
    .custom-checkbox { background-color: #262633; border: 1px solid #2d2d3d; width: 1.25rem; height: 1.25rem; border-radius: 6px; }
    .custom-checkbox:checked { background-color: #ff527b; border-color: #ff527b; }
</style>
<div class="custom-dashboard">
    <h1 class="custom-title m-0 text-center">Nuevo Recurso</h1>
    <div class="custom-hr"></div>
    <form asp-action="Crear" method="POST">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-4">
            <label asp-for="Nombre" class="form-label custom-label">Nombre</label>
            <input asp-for="Nombre" class="form-control custom-control" placeholder="Ingrese el nombre del recurso"/>
            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Tipo" class="form-label custom-label">Tipo</label>
            <input asp-for="Tipo" class="form-control custom-control" placeholder="Ingrese el tipo de recurso"/>
            <span asp-validation-for="Tipo" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="mb-4">
            <label asp-for="cantidad" class="form-label custom-label">Cantidad</label>
            <input asp-for="cantidad" class="form-control custom-control" placeholder="Defina la capacidad de la sala"/>
            <span asp-validation-for="cantidad" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="form-check mb-4 d-flex align-items-center gap-2">
            <input asp-for="Disponible" class="form-check-input custom-checkbox m-0"/>
            <label asp-for="Disponible" class="form-check-label custom-label m-0">Disponible</label>
        </div>
        <div class="d-flex justify-content-between align-items-center pt-2">
            <a asp-action="Index" class="btn-custom-back">Volver</a>
            <button type="submit" class="btn-custom-save">Guardar Recurso</button>
        </div>
    </form>
</div>
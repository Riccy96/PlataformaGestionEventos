@model IEnumerable<PlataformaGestionEventos.Models.Recurso>
@{
    ViewData["Title"] = "Lista de Recursos";
}
<style>
    .custom-dashboard {
        font-family: 'Poppins', sans-serif;
        background-color: #21212b;
        color: #b5b5be;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }
    .custom-title {
        font-weight: 600;
        color: #ffffff;
        font-size: 1.75rem;
    }
    .btn-custom-add {
        background: linear-gradient(135deg, #ff527b, #ff715b);
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 20px;
        font-weight: 500;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-custom-add:hover {
        background: linear-gradient(135deg, #ff715b, #ff527b);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(255, 82, 123, 0.4);
    }
    .custom-table-container {
        margin-top: 1.5rem;
    }
    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 12px;
        color: #a5a5b1;
    }
    .custom-table th {
        color: #7e7e8f;
        font-weight: 500;
        text-transform: capitalize;
        padding: 12px 16px;
        border: none;
        font-size: 0.9rem;
    }
    .custom-table tbody tr {
        background-color: #262633;
        transition: all 0.2s ease;
    }
    .custom-table tbody tr td:first-child {
        border-top-left-radius: 10px;
        border-bottom-left-radius: 10px;
        padding-left: 20px;
    }
    .custom-table tbody tr td:last-child {
        border-top-right-radius: 10px;
        border-bottom-right-radius: 10px;
        padding-right: 20px;
    }
    .custom-table tbody td {
        padding: 16px;
        border: none;
        vertical-align: middle;
        font-size: 0.95rem;
    }
    .custom-table tbody tr.row-highlighted {
        background: linear-gradient(90deg, #624b91, #3b508a);
        color: #ffffff;
    }
    .custom-table tbody tr.row-highlighted td {
        color: #ffffff;
    }
    .btn-action {
        background: transparent;
        border: none;
        color: #7e7e8f;
        padding: 6px 10px;
        font-size: 0.9rem;
        transition: color 0.2s;
        text-decoration: none;
    }
    .btn-action:hover { color: #ffffff; }
    .btn-action.edit:hover { color: #ffc107; }
    .btn-action.view:hover { color: #0dcaf0; }
    .btn-action.delete:hover { color: #dc3545; }
    .row-highlighted .btn-action { color: #e2e2e2; }
    .row-highlighted .btn-action:hover { color: #ffffff; }
    .badge-status {
        padding: 6px 12px;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 500;
    }
    .badge-status.active { background-color: rgba(40, 167, 69, 0.2); color: #28a745; }
    .badge-status.inactive { background-color: rgba(220, 53, 69, 0.2); color: #dc3545; }
    .row-highlighted .badge-status.active { background-color: rgba(255, 255, 255, 0.2); color: #fff; }
    .row-highlighted .badge-status.inactive { background-color: rgba(0, 0, 0, 0.2); color: #ff8080; }
</style>
<div class="custom-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="custom-title m-0">Recursos</h1>
        <a asp-action="Crear" class="btn-custom-add"><span>+</span> Nuevo Recurso</a>
    </div>
    <div class="table-responsive custom-table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Cantidad</th>
                    <th>Disponible</th>
                    <th style="width: 200px; text-align: center;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @{ bool esPrimeraFila = true; }
                @foreach (var recurso in Model)
                {
                    <tr class="@(esPrimeraFila ? "row-highlighted" : "")">
                        <td style="font-weight: 500;">@recurso.RecursoId</td>
                        <td>@recurso.Nombre</td>
                        <td>@recurso.Tipo</td>
                        <td>@recurso.cantidad</td>
                        <td>
                            @if (recurso.Disponible)
                            {
                                <span class="badge-status active">Sí</span>
                            }
                            else
                            {
                                <span class="badge-status inactive">No</span>
                            }
                        </td>
                        <td style="text-align: center;">
                            @if (esPrimeraFila)
                            {
                                <a asp-action="Editar" asp-route-id="@recurso.RecursoId" class="btn-action font-weight-bold" title="Editar">✓</a>
                                <a asp-action="Ver" asp-route-id="@recurso.RecursoId" class="btn-action view" title="Ver">👁️</a>
                                <a asp-action="Eliminar" asp-route-id="@recurso.RecursoId" class="btn-action font-weight-bold" title="Eliminar">✕</a>
                            }
                            else
                            {
                                <a asp-action="Editar" asp-route-id="@recurso.RecursoId" class="btn-action edit" title="Editar">✏️</a>
                                <a asp-action="Ver" asp-route-id="@recurso.RecursoId" class="btn-action view" title="Ver">👁️</a>
                                <a asp-action="Eliminar" asp-route-id="@recurso.RecursoId" class="btn-action delete" title="Eliminar">🗑️</a>
                            }
                        </td>
                    </tr>
                    esPrimeraFila = false;
                }
            </tbody>
        </table>
    </div>
</div>